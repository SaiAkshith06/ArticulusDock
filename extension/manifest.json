{
  "manifest_version": 3,
  "name": "Lumina Save",
  "version": "1.0",
  "description": "Save articles to your Lumina library with a single click.",
  "permissions": ["activeTab", "storage", "scripting", "tabs"],
  "content_scripts": [
    {
      "matches": ["*://*.run.app/*", "*://localhost/*", "*://*.vercel.app/*"],
      "js": ["content.js"]
    }
  ],
  "host_permissions": ["*://*/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "options_page": "settings.html",
  "background": {
    "service_worker": "background.js"
  }
}
